---
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import { getEntry } from 'astro:content'
import Base from '../layouts/base.astro'
import NextPrev from '../components/nextprev.astro'
import Categories from '../components/categories.astro'
import Tags from '../components/tags.astro'

export interface Props {
  post: CollectionEntry<'blog'>
  prev?: CollectionEntry<'blog'>
  next?: CollectionEntry<'blog'>
}

const { post, prev, next } = Astro.props
let author = await getEntry('author', 'default')
if (post.data.author) {
  author = await getEntry(post.data.author)
}
let cat = await getEntry('category', 'general')
if (post.data.categories) {
  cat = await getEntry(post.data.categories[0])
}
const heroImage = post.data.image || (post.data.images && post.data.images[0]) || cat!.data.image
---

<style>
  .post-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem;
    overflow: hidden;
  }
  .post-hero-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .post-hero-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.58);
    z-index: 1;
  }
  .post-hero-content {
    position: relative;
    z-index: 2;
    max-width: 48rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .post-hero-title {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 6vw, 5rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.8);
    margin: 0;
  }
  .post-hero-description {
    font-family: 'Noto Serif', serif;
    font-size: clamp(1rem, 2vw, 1.4rem);
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.7);
    margin: 0;
  }
  .post-hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.75);
  }
  .post-hero-meta-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: rgba(255, 255, 255, 0.5);
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    animation: bounce 2s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes bounce {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(6px);
    }
  }
  .post-body {
    position: relative;
    z-index: 10;
    background: #0a0a0f;
    padding-top: 4rem;
    padding-bottom: 6rem;
  }
</style>

<Base frontmatter={post.data}>
  <main transition:animate="fade">
    <article class="post">
      <!-- Full-viewport hero -->
      <header class="post-hero">
        <Image
          src={heroImage}
          alt={post.data.title ?? ''}
          class="post-hero-bg"
          width={1920}
          height={1080}
        />
        <div class="post-hero-overlay"></div>
        <div class="post-hero-content">
          {post.data.categories && <Categories categories={post.data.categories} />}
          <h1 class="post-hero-title">{post.data.title}</h1>
          {post.data.description && <p class="post-hero-description">{post.data.description}</p>}
          <div class="post-hero-meta">
            {
              post.data.author && (
                <span class="post-hero-meta-item">
                  <Image
                    src={author!.data.image}
                    alt={author!.data.title}
                    class="rounded-full object-cover"
                    width={28}
                    height={28}
                  />
                  <span>{author!.data.title}</span>
                </span>
              )
            }
            {
              post.data.pubDate && (
                <span class="post-hero-meta-item">
                  <span class="i-heroicons-calendar-days h-4 w-4" />
                  <span>{new Date(post.data.pubDate).toDateString()}</span>
                </span>
              )
            }
            {
              post.data.minutesRead && (
                <span class="post-hero-meta-item">
                  <span class="i-heroicons-clock h-4 w-4" />
                  <span>{post.data.minutesRead}</span>
                </span>
              )
            }
          </div>
          {post.data.tags && <Tags tags={post.data.tags} />}
        </div>
        <div class="scroll-hint" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
          </svg>
          <span>READ</span>
        </div>
      </header>

      <!-- Article body sits on top of fixed image as reader scrolls -->
      <section class="post-body">
        <div
          class="mx-auto px-4 max-w-prose prose prose-invert lg:px-0"
          style="font-family: 'Noto Serif', serif; line-height: 1.8; max-width: 65ch;"
        >
          <slot />
        </div>
      </section>
    </article>
  </main>
  <NextPrev
    slot="before-footer"
    base={`${import.meta.env.BASE_URL}` + 'blog/'}
    prev={prev}
    next={next}
  />
</Base>

<script>
  // Hide fixed hero image once article body scrolls into view
  const postBody = document.querySelector('.post-body') as HTMLElement | null
  const overlay = document.querySelector('.post-hero-overlay') as HTMLElement | null
  const heroBg = document.querySelector('.post-hero-bg') as HTMLElement | null

  if (postBody && overlay && heroBg) {
    const obs = new IntersectionObserver(
      ([entry]) => {
        const hidden = entry.isIntersecting
        overlay.style.transition = 'opacity 400ms ease'
        heroBg.style.transition = 'opacity 400ms ease'
        overlay.style.opacity = hidden ? '0' : '1'
        heroBg.style.opacity = hidden ? '0' : '1'
      },
      { threshold: 0.15 }
    )
    obs.observe(postBody)
  }
</script>
