---
import { getCollection } from 'astro:content'
import { Logo } from '../config'

const social = await getCollection('social')
---

<div class="h-24 lg:h-16"></div>
<footer class="text-gray-600 dark:text-gray-400">
  <div
    class="px-4 py-1 border-t-2 border-purple-300 bg-gray-100 flex flex-col w-full items-center inset-x-0 bottom-0 fixed z-20 lg:px-8 lg:py-4 dark:border-purple-600 dark:bg-gray-800 lg:flex-row"
  >
    <span class="flex flex-none flex-row items-center">
      <a
        class="title-font dark:text:gray-100 text-gray-900 font-medium flex items-center justify-center lg:justify-start"
        href={`${import.meta.env.BASE_URL}`}
      >
        <img src={Logo.src} alt="Footer Logo" class="h-6 w-6 dark:bg-gray-100" loading="lazy" />
        <span class="sr-only">Logo</span>
      </a>
      <p
        class="text-sm text-gray-600 ml-2 py-1 pl-2 border-l-2 border-purple-300 dark:text-gray-300 dark:border-purple-600"
      >
        © {new Date().getFullYear()} MIT licence
        <a
          href="https://hellotham.com"
          class="text-purple-600 ml-1 dark:text-purple-300 hover:text-pink-600 dark:hover:text-pink-300"
          rel="noopener noreferrer"
          target="_blank"
        >
          Hello Tham Pty Ltd
        </a>
      </p>
    </span>
    <span class="flex flex-none flex-row items-center">
      <p
        class="text-sm text-gray-600 dark:text-gray-300 lg:ml-4 lg:py-1 lg:pl-4 lg:border-l-2 lg:border-purple-300 dark:lg:border-purple-600"
      >
        <a
          href={`${import.meta.env.BASE_URL}` + 'privacy'}
          class="text-purple-600 ml-1 dark:text-purple-300 hover:text-pink-600 dark:hover:text-pink-300"
        >
          Privacy Policy
        </a>
      </p>
      <p class="text-sm text-gray-600 ml-4 py-1 pl-4 border-l-2 border-purple-300">
        <a
          href={`${import.meta.env.BASE_URL}` + 'rss.xml'}
          class="text-purple-600 ml-1 dark:text-purple-300 hover:text-pink-600 dark:hover:text-pink-300"
          rel="noopener noreferrer"
          target="_blank"
        >
          RSS
        </a>
      </p>
      <p
        class="text-sm text-gray-600 ml-4 py-1 pl-4 border-l-2 border-purple-300 dark:text-gray-300"
      >
        <a
          href={`${import.meta.env.BASE_URL}` + 'sitemap-index.xml'}
          class="text-purple-600 ml-1 dark:text-purple-300 hover:text-pink-600 dark:hover:text-pink-300"
          rel="noopener noreferrer"
          target="_blank"
        >
          Sitemap
        </a>
      </p>
    </span>
    <span class="mt-2 inline-flex grow justify-center lg:ml-auto lg:mt-0 lg:justify-end">
      {
        social.map((s) =>
          s.data.link ? (
            <a
              href={s.data.link}
              class="text-purple-600 ml-3 dark:text-purple-300 hover:text-pink-600 dark:hover:text-pink-300"
              rel="noopener noreferrer"
              target="_blank"
            >
              <div class={'h-5 w-5 i-bi-' + s.data.icon} />
              <span class="sr-only">{s.data.name}</span>
            </a>
          ) : (
            ''
          )
        )
      }
    </span>
  </div>
</footer>
