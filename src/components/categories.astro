---
import type { CollectionEntry } from 'astro:content'
import { getEntries } from 'astro:content'

export interface Props {
  categories: { collection: 'category', id: string }[]
}

const { categories } = Astro.props as Props
const cats = (await getEntries(categories)) as CollectionEntry<'category'>[]
---

{
  categories && (
    <div class='flex flex-row flex-wrap items-start gap-2 pb-2'>
      {cats.map((category) => (
        <a
          href={`${`${import.meta.env.BASE_URL}`}category/${encodeURIComponent(category.id)}/`}
          class='inline-block rounded bg-purple-600 px-3 py-1 text-xs text-white font-medium tracking-tight uppercase hover:bg-pink-600'
        >
          {category.data.title}
          <span class='sr-only'>category</span>
        </a>
      ))}
    </div>
  )
}
