---
import type { CollectionEntry } from 'astro:content'
import { getEntry } from 'astro:content'
import { Image } from 'astro:assets'
import Categories from '../components/categories.astro'
import Tags from '../components/tags.astro'

export interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props

let cat = await getEntry('category', 'general')
if (post.data.categories) {
  cat = (await getEntry(
    post.data.categories[0].collection,
    post.data.categories[0].id
  )) as CollectionEntry<'category'>
}
const image = post.data.image || (post.data.images && post.data.images[0]) || cat!.data.image
let author = await getEntry('author', 'default')
if (post.data.author) {
  author = (await getEntry(
    post.data.author.collection,
    post.data.author.id
  )) as CollectionEntry<'author'>
}
---

<style>
  .blog-card {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    aspect-ratio: 3 / 4;
    min-height: 20rem;
    transition:
      transform 300ms ease,
      box-shadow 300ms ease;
    display: block;
    text-decoration: none;
  }
  .blog-card:hover {
    transform: scale(1.02);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
  }
  .blog-card-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .blog-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.88) 0%,
      rgba(0, 0, 0, 0.4) 55%,
      rgba(0, 0, 0, 0.05) 100%
    );
    z-index: 1;
  }
  .blog-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 1rem;
  }
  .blog-card-title {
    font-family: 'Noto Serif', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.35;
    margin: 0.25rem 0 0.4rem;
  }
  .blog-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.7);
    align-items: center;
  }
</style>

<a
  class="blog-card"
  href={`${import.meta.env.BASE_URL}` + 'blog/' + post.id}
  aria-label={post.data.title}
>
  <Image
    src={image}
    alt={post.data.title + ' featured image'}
    class="blog-card-image"
    width={400}
    height={533}
  />
  <div class="blog-card-overlay"></div>
  <div class="blog-card-content">
    {post.data.categories && <Categories categories={post.data.categories} />}
    <h2 class="blog-card-title">{post.data.title}</h2>
    <div class="blog-card-meta">
      {
        post.data.pubDate && (
          <span class="flex gap-1 items-center">
            <span class="i-heroicons-calendar-days h-3 w-3" />
            {post.data.pubDate.toDateString()}
          </span>
        )
      }
      {
        post.data.minutesRead && (
          <span class="flex gap-1 items-center">
            <span class="i-heroicons-clock h-3 w-3" />
            {post.data.minutesRead}
          </span>
        )
      }
      {
        post.data.author && (
          <span class="flex gap-1 items-center">
            <span class="i-heroicons-user-circle h-3 w-3" />
            {author!.data.title}
          </span>
        )
      }
    </div>
    <Tags tags={post.data.tags} />
  </div>
</a>
