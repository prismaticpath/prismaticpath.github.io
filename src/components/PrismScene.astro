---
import type { CollectionEntry } from 'astro:content'

export interface Props {
  posts: CollectionEntry<'blog'>[]
  baseUrl: string
}

const { posts, baseUrl } = Astro.props

interface PostData {
  id: string
  title: string
  url: string
  category: string
}

const postData: PostData[] = posts.map((p) => ({
  id: p.id,
  title: p.data.title ?? p.id,
  url: baseUrl + 'blog/' + p.id,
  category: p.data.categories?.[0]?.id ?? 'general'
}))
---

<style>
  #prism-wrapper {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: #05050f;
  }
  #prism-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  #post-beams {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  #post-beams a {
    text-decoration: none;
  }
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: rgba(255, 255, 255, 0.5);
    font-family: 'Noto Sans', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    animation: bounce 2s ease-in-out infinite;
    pointer-events: none;
    z-index: 10;
  }
  @keyframes bounce {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(6px);
    }
  }
  .scroll-hint svg {
    width: 1.5rem;
    height: 1.5rem;
  }
</style>

<div id="prism-wrapper" data-posts={JSON.stringify(postData)}>
  <canvas id="prism-canvas"></canvas>
  <div id="post-beams"></div>
  <div class="scroll-hint" aria-hidden="true">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
    </svg>
    <span>SCROLL</span>
  </div>
</div>
<div id="blog-start"></div>

<script>
  import { initPrism } from '../scripts/prism'
  initPrism()
  document.addEventListener('astro:page-load', () => initPrism())
</script>
