---
import { NavigationLinks } from '../config'
import Search from '../components/search.astro'
---

<style>
  .rainbow-text {
    background: linear-gradient(90deg, #ff0080, #ff8c00, #ffe100, #00c800, #00bfff, #9b59b6, #ff0080);
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: rainbow-shift 6s linear infinite;
    font-weight: 900;
    letter-spacing: 0.05em;
    font-family: 'Noto Sans', sans-serif;
  }
  @keyframes rainbow-shift {
    0%   { background-position: 0% 50% }
    100% { background-position: 300% 50% }
  }
</style>

<div class="h-16 w-full relative">
  <nav x-data="{ isOpen: false }" style="background: rgba(10,10,20,0.6); backdrop-filter: blur(12px);">
    <div
      class="mx-auto px-2 w-full fixed z-50 lg:px-8 sm:px-6"
      style="background: rgba(10,10,20,0.6); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.1);"
    >
      <div class="flex h-16 items-center justify-between relative">
        <div class="flex items-center inset-y-0 left-0 absolute lg:hidden">
          <!-- Mobile menu button-->
          <button
            type="button"
            x-on:click="isOpen = !isOpen"
            class="text-purple-300 p-2 rounded-md inline-flex items-center justify-center hover:text-pink-300 focus:outline-none hover:bg-purple-800 focus:ring-2 focus:ring-purple-700 focus:ring-inset"
            aria-controls="mobile-menu"
            aria-expanded="false"
          >
            <span class="sr-only">Open main menu</span>
            <div
              x-bind:class="{'hidden': isOpen, 'block': !isOpen }"
              class="i-heroicons-bars-3 h-6 w-6 block"
              aria-hidden="true"
            >
            </div>
            <div
              x-bind:class="{'block': isOpen, 'hidden': !isOpen }"
              class="i-heroicons-x-mark h-6 w-6 hidden"
              aria-hidden="true"
            >
            </div>
          </button>
        </div>
        <div class="flex flex-1 items-center justify-center lg:items-stretch lg:justify-start">
          <div class="flex flex-shrink-0 items-center">
            <a href={`${import.meta.env.BASE_URL}`} class="rainbow-text text-xl no-underline">
              Prismatic Path
            </a>
          </div>
          <div class="hidden lg:mx-4 lg:block">
            <div class="flex space-x-2">
              {
                NavigationLinks.map((item) => (
                  <a
                    href={`${import.meta.env.BASE_URL}` + item.href}
                    class={
                      (item.href.length > 0 && Astro.url.toString().includes(item.href)
                        ? 'bg-purple-800 text-pink-300'
                        : 'text-white/80 hover:bg-purple-800 hover:text-white') +
                      ' rounded-md px-2 py-2 text-lg font-medium transition-colors duration-200'
                    }
                    aria-current={
                      item.href.length > 0 && Astro.url.toString().includes(item.href)
                        ? 'page'
                        : undefined
                    }
                  >
                    {item.name}
                  </a>
                ))
              }
            </div>
          </div>
        </div>
        <div
          class="pr-2 flex items-center inset-y-0 right-0 absolute sm:ml-6 sm:pr-0 sm:inset-auto sm:static"
        >
          <Search />
        </div>
      </div>
    </div>

    <!-- Mobile menu, show/hide based on menu state. -->
    <div
      x-show="isOpen"
      x-cloak
      x-transition:enter="transition ease-out duration-100 transform"
      x-transition:enter-start="opacity-0 scale-95"
      x-transition:enter-end="opacity-100 scale-100"
      x-transition:leave="transition ease-in duration-75 transform"
      x-transition:leave-start="opacity-100 scale-100"
      x-transition:leave-end="opacity-0 scale-95"
      class="inset-x-0 top-16 absolute z-50"
      id="mobile-menu"
    >
      <div
        class="font-semibold px-4 py-2 flex justify-center"
        style="background: rgba(10,10,20,0.9); border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);"
      >
        {
          NavigationLinks.map((item) => (
            <a
              href={`${import.meta.env.BASE_URL}` + item.href}
              class:list={[
                item.href.length > 0 && Astro.url.toString().includes(item.href)
                  ? 'bg-purple-800 text-pink-300'
                  : 'text-white/80 hover:bg-purple-800 hover:text-white',
                ' px-2 py-1 rounded transition-colors duration-200'
              ]}
              aria-current={
                item.href.length > 0 && Astro.url.toString().includes(item.href)
                  ? 'page'
                  : undefined
              }
            >
              {item.name}
            </a>
          ))
        }
      </div>
    </div>
  </nav>
</div>
