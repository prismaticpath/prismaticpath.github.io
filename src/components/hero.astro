---
import { SiteMetadata } from '../config'
---

<style>
  .rainbow-title {
    background: linear-gradient(90deg, #ff0080, #ff8c00, #ffe100, #00c800, #00bfff, #9b59b6, #ff0080);
    background-size: 300% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: rainbow-shift 6s linear infinite;
    font-weight: 900;
    letter-spacing: 0.04em;
    font-family: 'Noto Sans', sans-serif;
    line-height: 1.1;
    font-size: clamp(3rem, 10vw, 8rem);
  }
  @keyframes rainbow-shift {
    0%   { background-position: 0% 50% }
    100% { background-position: 300% 50% }
  }
</style>

<section class="relative overflow-hidden" style="background: #05050f;">
  <div class="mx-auto max-w-7xl px-4 pt-20 pb-16 lg:px-8 sm:px-6 flex flex-col items-center text-center">
    <h1 class="rainbow-title">
      {SiteMetadata.title}
    </h1>
    <p class="text-gray-300 mt-6 max-w-2xl text-lg leading-relaxed" style="font-family: 'Noto Serif', serif;">
      {SiteMetadata.description}
    </p>
    <div class="mt-8 flex gap-4">
      <a
        href="/about"
        class="text-white font-medium px-8 py-3 rounded-md bg-purple-700 hover:bg-pink-600 transition-colors duration-200"
      >
        About
      </a>
      <a
        href="https://github.com/sponsors/hellotham"
        class="text-purple-200 font-medium px-8 py-3 rounded-md bg-purple-900 hover:bg-pink-900 transition-colors duration-200"
        rel="noopener noreferrer"
        target="_blank"
      >
        Sponsor Us
      </a>
    </div>
  </div>
</section>
