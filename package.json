{
  "name": "prismatic-ghost",
  "description": "Export of Prismatic Path Ghost site plus conversion into markdown using ghostToHugo.",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "clean": "rm -rf node_modules .astro dist",
    "start": "astro dev",
    "build": "astro build; prettier --write  \"dist/**/*.{js,html,css}\"",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "pnpm run lint:prettier && pnpm run lint:eslint",
    "lint:prettier": "prettier --write  \"src/**/*.{js,jsx,ts,tsx,md,mdx,astro}\"",
    "lint:eslint": "eslint --fix \"src/**/*.{js,ts,jsx,tsx,md,astro}\"",
    "refresh": "pnpm dlx @astrojs/upgrade; pnpm up -L",
    "astro": "astro"
  },
  "devDependencies": {
    "@astrojs/alpinejs": "^0.5.0",
    "@astrojs/sitemap": "^3.7.2",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/heroicons": "^1.2.3",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^25.6.0",
    "@unocss/astro": "^66.6.8",
    "@unocss/eslint-config": "^66.6.8",
    "alpinejs": "^3.15.11",
    "astro": "^6.1.5",
    "astro-robots-txt": "^1.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "exifr": "^7.1.3",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "remark-emoji": "^5.0.2",
    "schema-dts": "^2.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "unist-util-visit": "^5.1.0",
    "unocss": "^66.6.8"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/rss": "^4.0.18",
    "@fontsource/noto-sans": "^5.2.10",
    "@fontsource/noto-serif": "^5.2.9",
    "@types/three": "^0.183.1",
    "astro-seo": "^1.1.0",
